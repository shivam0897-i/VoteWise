# Required: Your Gemini API key. Create one at https://aistudio.google.com/apikey
# This is exposed to browser code via Vite. For production, use a backend proxy.
VITE_GEMINI_API_KEY=

# Optional: public JSON feed with the same shape as src/data/electionData.js
VITE_ELECTION_DATA_URL=

# Optional: default model is gemini-2.5-flash
VITE_GEMINI_MODEL=

# Optional: set to false if your API key/project cannot use Search grounding
VITE_ENABLE_SEARCH_GROUNDING=true

# Optional: Google Maps Embed API key for booth finder map
VITE_GOOGLE_MAPS_KEY=
