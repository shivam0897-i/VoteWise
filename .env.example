# Server-side only: Gemini API key for the Cloud Function proxy.
# Do not expose this value to the frontend or commit a real key.
GEMINI_API_KEY=

# Browser-safe: Google Cloud Functions proxy that calls Gemini server-side.
# This keeps the API key in Secret Manager / function env instead of browser code.
GEMINI_PROXY_URL=

# Optional: public JSON feed with the same shape as src/data/electionData.js
ELECTION_DATA_URL=

# Optional: default model is gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash

# Optional: set to false if your API key/project cannot use Search grounding
ENABLE_SEARCH_GROUNDING=true

# Optional: Google Maps Embed API key for booth finder map
GOOGLE_MAPS_KEY=
